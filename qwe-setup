#!/bin/bash
# qwe-setup - configure and manage the qwe local LLM stack
#
# Subcommands:
#   wizard           — interactive setup (configure only; run install.sh first for deps)
#   ensure-profile   — append a model profile to llama-swap config if absent
#   start            — start llama-swap as a background daemon
#   status           — show install / running state

QWE_CONFIG_DIR="${HOME}/.config/qwe"
QWE_CONFIG="${QWE_CONFIG_DIR}/config"
LLAMA_SWAP_CONFIG_DIR="${HOME}/.config/llama-swap"
LLAMA_SWAP_CONFIG="${LLAMA_SWAP_CONFIG_DIR}/config.yaml"
PID_FILE="${QWE_CONFIG_DIR}/llama-swap.pid"
FROGGERIC_TEMPLATE="${LLAMA_SWAP_CONFIG_DIR}/qwen3.6-froggeric.jinja"
FROGGERIC_URL="https://huggingface.co/froggeric/Qwen-Fixed-Chat-Templates/resolve/main/qwen3.6/chat_template.jinja"

# Model tier lookup helpers (bash 3.2 compatible, kept in sync with qwe)
tier_profile() {
    case "$1" in
        light)      echo "qwe-light" ;;
        balanced)   echo "qwe-balanced" ;;
        balanced+)  echo "qwe-balanced-plus" ;;
        smart)      echo "qwe-smart" ;;
        *)          echo "" ;;
    esac
}

tier_hf() {
    case "$1" in
        light)      echo "google/gemma-4-E4B-it-qat-q4_0-gguf" ;;
        balanced)   echo "google/gemma-4-12B-it-qat-q4_0-gguf" ;;
        balanced+)  echo "unsloth/gemma-4-12b-it-GGUF:UD-Q8_K_XL" ;;
        smart)      echo "unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q6_K" ;;
        *)          echo "" ;;
    esac
}

tier_ram() {
    case "$1" in
        light)      echo "~3 GB" ;;
        balanced)   echo "~8 GB" ;;
        balanced+)  echo "~14 GB" ;;
        smart)      echo "~28 GB" ;;
        *)          echo "?" ;;
    esac
}

tier_ctx() {
    case "$1" in
        light)      echo "16384" ;;
        balanced)   echo "16384" ;;
        balanced+)  echo "32768" ;;
        smart)      echo "16384" ;;
        *)          echo "16384" ;;
    esac
}

tier_name() {
    case "$1" in
        light)      echo "Gemma 4 4B QAT-Q4" ;;
        balanced)   echo "Gemma 4 12B QAT-Q4" ;;
        balanced+)  echo "Gemma 4 12B UD-Q8_K_XL" ;;
        smart)      echo "Qwen3.6 35B UD-Q6_K" ;;
        *)          echo "$1" ;;
    esac
}

tier_description() {
    case "$1" in
        light)      echo "google/gemma-4-E4B-it-qat-q4_0-gguf — fastest, lowest RAM" ;;
        balanced)   echo "google/gemma-4-12B-it-qat-q4_0-gguf — good balance of speed and quality" ;;
        balanced+)  echo "unsloth/gemma-4-12b-it-GGUF:UD-Q8_K_XL — high quality mid-size" ;;
        smart)      echo "unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q6_K — maximum quality" ;;
        *)          echo "" ;;
    esac
}

is_valid_tier() {
    case "$1" in
        light|balanced|balanced+|smart) return 0 ;;
        *) return 1 ;;
    esac
}

BOLD=$'\e[1m'
RESET=$'\e[0m'
GREEN=$'\e[32m'
YELLOW=$'\e[33m'
RED=$'\e[31m'
CYAN=$'\e[36m'

info()    { printf "${CYAN}→${RESET} %s\n" "$*"; }
ok()      { printf "${GREEN}✓${RESET} %s\n" "$*"; }
warn()    { printf "${YELLOW}!${RESET} %s\n" "$*" >&2; }
err()     { printf "${RED}✗${RESET} %s\n" "$*" >&2; }
step()    { printf "\n${BOLD}%s${RESET}\n" "$*"; }

# --- dependency check ---------------------------------------------------------
# Call before any subcommand that needs llama-server/llama-swap/jq.
# Tells the user to run install.sh if anything is missing.
check_deps() {
    local missing=()
    command -v llama-server &>/dev/null || missing+=("llama-server")
    command -v llama-swap   &>/dev/null || missing+=("llama-swap")
    command -v jq           &>/dev/null || missing+=("jq")
    if [[ ${#missing[@]} -gt 0 ]]; then
        err "Missing dependencies: ${missing[*]}"
        local repo_dir
        repo_dir="$(cd "$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
        info "Run: bash \"$repo_dir/install.sh\"  to install missing components."
        return 1
    fi
}

# --- llama-swap config management ---------------------------------------------
profile_exists() {
    local profile="$1"
    [[ -f "$LLAMA_SWAP_CONFIG" ]] && grep -q "^  ${profile}:" "$LLAMA_SWAP_CONFIG"
}

# Emit YAML for a Gemma profile (light / balanced / balanced+)
# Args: tier  profile-name  hf-repo  ctx-size
gemma_profile_yaml() {
    local tier="$1" profile="$2" hf="$3" ctx="$4"
    cat <<YAML

  ${profile}:
    name: "$(tier_name "$tier")"
    description: "$(tier_description "$tier")"
    cmd: |
      \${llama-server}
      -hf ${hf}
      --ctx-size ${ctx}
      --temp 1.0
      --top-p 0.95
      --top-k 64
      --chat-template-kwargs '{"enable_thinking":false}'
      --port \${PORT}
    ttl: 7200
YAML
}

# Emit YAML for the Qwen smart profile (reuses existing macros)
smart_profile_yaml() {
    cat <<YAML

  qwe-smart:
    name: "$(tier_name smart)"
    description: "$(tier_description smart)"
    cmd: |
      \${llama-server}
      \${common-flags}
      --ctx-size 16384
      --temp 0.7
      --top-p 0.8
      --presence-penalty 1.5
    ttl: 7200
YAML
}

# Emit YAML for a full fresh config (new installs)
generate_fresh_config() {
    local llama_server_bin="$1"
    local default_tier="$2"
    local preload_profile
    preload_profile=$(tier_profile "$default_tier")
    cat <<YAML
# llama-swap config generated by qwe-setup
# Edit freely — qwe-setup will only append new profiles, never overwrite existing ones.

macros:
  llama-server: "${llama_server_bin}"
  template: "\${env.HOME}/.config/llama-swap/qwen3.6-froggeric.jinja"
  common-flags: >
    --port \${PORT}
    -hf unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q6_K
    -ngl 99
    --flash-attn on
    --jinja
    --chat-template-file \${template}
    --top-k 20
    --min-p 0.0
    --repeat-penalty 1.0
    --spec-type draft-mtp
    --spec-draft-n-max 2

models:
YAML
    gemma_profile_yaml "light"     "qwe-light"         "$(tier_hf light)"     "$(tier_ctx light)"
    gemma_profile_yaml "balanced"  "qwe-balanced"      "$(tier_hf balanced)"  "$(tier_ctx balanced)"
    gemma_profile_yaml "balanced+" "qwe-balanced-plus" "$(tier_hf balanced+)" "$(tier_ctx balanced+)"
    smart_profile_yaml
    cat <<YAML

startPort: 9999

hooks:
  on_startup:
    preload:
      - "${preload_profile}"
YAML
}

cmd_ensure_profile() {
    local tier="$1"
    if ! is_valid_tier "$tier"; then
        err "Unknown tier: $tier"
        return 1
    fi

    local profile
    profile=$(tier_profile "$tier")

    if profile_exists "$profile"; then
        return 0
    fi

    if [[ ! -f "$LLAMA_SWAP_CONFIG" ]]; then
        warn "llama-swap config not found. Run: qwe setup"
        return 1
    fi

    info "Adding profile '$profile' to $LLAMA_SWAP_CONFIG..."

    local profile_yaml
    if [[ "$tier" == "smart" ]]; then
        ensure_froggeric_template
        profile_yaml=$(smart_profile_yaml)
    else
        profile_yaml=$(gemma_profile_yaml "$tier" "$profile" "$(tier_hf "$tier")" "$(tier_ctx "$tier")")
    fi

    # Insert inside the models: section — before startPort:/hooks:/groups: (top-level keys)
    local insert_line
    insert_line=$(grep -n '^startPort:\|^hooks:\|^groups:' "$LLAMA_SWAP_CONFIG" \
        | head -1 | cut -d: -f1)

    if [[ -n "$insert_line" ]]; then
        local tmp
        tmp=$(mktemp)
        head -n $((insert_line - 1)) "$LLAMA_SWAP_CONFIG" > "$tmp"
        printf '%s\n' "$profile_yaml" >> "$tmp"
        tail -n +"$insert_line" "$LLAMA_SWAP_CONFIG" >> "$tmp"
        mv "$tmp" "$LLAMA_SWAP_CONFIG"
    else
        printf '%s\n' "$profile_yaml" >> "$LLAMA_SWAP_CONFIG"
    fi

    ok "Profile '$profile' added."

    # Signal llama-swap to reload its config (SIGHUP triggers hot reload)
    local swap_pid
    swap_pid=$(pgrep -f "llama-swap --config" 2>/dev/null | head -1)
    if [[ -n "$swap_pid" ]]; then
        kill -HUP "$swap_pid" 2>/dev/null && sleep 1
    fi
}

ensure_froggeric_template() {
    if [[ ! -f "$FROGGERIC_TEMPLATE" ]]; then
        info "Downloading Qwen froggeric chat template..."
        mkdir -p "$LLAMA_SWAP_CONFIG_DIR"
        curl -L --progress-bar -o "$FROGGERIC_TEMPLATE" "$FROGGERIC_URL" \
            && ok "Template saved to $FROGGERIC_TEMPLATE" \
            || warn "Template download failed. Smart tier may not suppress thinking."
    fi
}

# --- start llama-swap ---------------------------------------------------------
cmd_start() {
    check_deps || return 1

    if [[ ! -f "$LLAMA_SWAP_CONFIG" ]]; then
        err "No config at $LLAMA_SWAP_CONFIG. Run: qwe setup"
        return 1
    fi

    # Stop any stale instance
    if [[ -f "$PID_FILE" ]]; then
        local old_pid
        old_pid=$(cat "$PID_FILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            info "llama-swap already running (PID $old_pid)."
            return 0
        fi
        rm -f "$PID_FILE"
    fi

    mkdir -p "$QWE_CONFIG_DIR"
    local log_file="${QWE_CONFIG_DIR}/llama-swap.log"
    nohup llama-swap \
        --config "$LLAMA_SWAP_CONFIG" \
        --listen "localhost:8080" \
        > "$log_file" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    ok "llama-swap started (PID $pid). Log: $log_file"
}

# --- status -------------------------------------------------------------------
cmd_status() {
    step "qwe-setup status"

    printf "  llama-server: "
    command -v llama-server &>/dev/null \
        && printf "${GREEN}%s${RESET}\n" "$(command -v llama-server)" \
        || printf "${RED}not found${RESET}\n"

    printf "  llama-swap:   "
    command -v llama-swap &>/dev/null \
        && printf "${GREEN}%s${RESET}\n" "$(command -v llama-swap)" \
        || printf "${RED}not found${RESET}\n"

    printf "  jq:           "
    command -v jq &>/dev/null \
        && printf "${GREEN}%s${RESET}\n" "$(command -v jq)" \
        || printf "${RED}not found${RESET}\n"

    printf "  Config:       "
    [[ -f "$LLAMA_SWAP_CONFIG" ]] \
        && printf "${GREEN}%s${RESET}\n" "$LLAMA_SWAP_CONFIG" \
        || printf "${RED}not found${RESET}\n"

    printf "  PID file:     "
    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            printf "${GREEN}running (PID %s)${RESET}\n" "$pid"
        else
            printf "${YELLOW}stale (PID %s not running)${RESET}\n" "$pid"
        fi
    else
        printf "none\n"
    fi
}

# --- setup wizard -------------------------------------------------------------
cmd_wizard() {
    check_deps || return 1

    printf "\n${BOLD}Welcome to qwe setup${RESET}\n"
    printf "This wizard configures the local LLM stack.\n\n"

    # Step 1/2: choose model tier
    step "Step 1/2: Choose default model tier"
    printf "  [1] light      (%s)  — fast, small\n"      "$(tier_ram light)"
    printf "  [2] balanced   (%s)  — good balance\n"     "$(tier_ram balanced)"
    printf "  [3] balanced+  (%s) — high quality\n"      "$(tier_ram balanced+)"
    printf "  [4] smart      (%s) — maximum quality\n\n" "$(tier_ram smart)"
    local current_tier="smart"
    [[ -f "$QWE_CONFIG" ]] && source "$QWE_CONFIG" && current_tier="$MODEL_TIER"
    printf "Choice [current: %s, default: 4]: " "$current_tier"
    read -r choice
    local chosen_tier
    case "$choice" in
        1) chosen_tier="light" ;;
        2) chosen_tier="balanced" ;;
        3) chosen_tier="balanced+" ;;
        4) chosen_tier="smart" ;;
        *) chosen_tier="$current_tier" ;;
    esac
    ok "Selected: $chosen_tier  ($(tier_name "$chosen_tier"),  $(tier_ram "$chosen_tier") RAM)"

    # Step 2/2: configure llama-swap + write qwe config
    step "Step 2/2: Configuring"
    mkdir -p "$LLAMA_SWAP_CONFIG_DIR"

    if [[ -f "$LLAMA_SWAP_CONFIG" ]]; then
        ok "Existing llama-swap config found at $LLAMA_SWAP_CONFIG"
        info "Appending any missing qwe profiles..."
        for tier in light balanced balanced+ smart; do
            cmd_ensure_profile "$tier"
        done
    else
        info "No existing config — creating one."
        local llama_bin
        llama_bin=$(command -v llama-server 2>/dev/null || echo "/opt/homebrew/bin/llama-server")
        printf "llama-server binary path [%s]: " "$llama_bin"
        read -r input_bin
        [[ -n "$input_bin" ]] && llama_bin="$input_bin"
        ensure_froggeric_template
        generate_fresh_config "$llama_bin" "$chosen_tier" > "$LLAMA_SWAP_CONFIG"
        ok "llama-swap config written to $LLAMA_SWAP_CONFIG"
    fi

    mkdir -p "$QWE_CONFIG_DIR"
    printf 'MODEL_TIER=%s\nENDPOINT=http://localhost:8080\n' "$chosen_tier" > "$QWE_CONFIG"
    ok "qwe config written: $QWE_CONFIG"

    printf "\nStart llama-swap now? [Y/n]: "
    read -r start_now
    if [[ "$start_now" != "n" && "$start_now" != "N" ]]; then
        cmd_start
    fi

    printf "\n${GREEN}${BOLD}Setup complete!${RESET}\n"
    printf "  qwe status          — verify everything is running\n"
    printf "  qwe \"hello world\"   — test a query\n"
    printf "  qwe light           — switch to a lighter model\n\n"
}

# --- dispatch -----------------------------------------------------------------
case "${1:-wizard}" in
    wizard)          cmd_wizard ;;
    ensure-profile)  cmd_ensure_profile "$2" ;;
    start)           cmd_start ;;
    status)          cmd_status ;;
    *)
        echo "Usage: qwe-setup {wizard|ensure-profile <tier>|start|status}" >&2
        exit 1
        ;;
esac
